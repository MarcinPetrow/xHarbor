{
  "name": "xharbor",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "xharbor",
      "workspaces": [
        "apps/*",
        "packages/*"
      ]
    },
    "apps/xbacklog-api": {
      "name": "@xharbor/xbacklog-api",
      "version": "0.1.0",
      "dependencies": {
        "@xharbor/contracts": "0.1.0",
        "@xharbor/platform-auth": "0.1.0",
        "@xharbor/platform-session": "0.1.0",
        "@xharbor/sqlite-store": "0.1.0"
      }
    },
    "apps/xbacklog-web": {
      "name": "@xharbor/xbacklog-web",
      "version": "0.1.0"
    },
    "apps/xdashboard-api": {
      "name": "@xharbor/xdashboard-api",
      "dependencies": {
        "@xharbor/contracts": "*",
        "@xharbor/platform-auth": "*",
        "@xharbor/platform-session": "*",
        "@xharbor/sqlite-store": "*"
      }
    },
    "apps/xdashboard-web": {
      "name": "@xharbor/xdashboard-web"
    },
    "apps/xgroup-api": {
      "name": "@xharbor/xgroup-api",
      "version": "0.1.0",
      "dependencies": {
        "@xharbor/contracts": "0.1.0",
        "@xharbor/platform-auth": "0.1.0",
        "@xharbor/platform-session": "0.1.0",
        "@xharbor/sqlite-store": "0.1.0"
      }
    },
    "apps/xgroup-web": {
      "name": "@xharbor/xgroup-web",
      "version": "0.1.0"
    },
    "apps/xtalk-api": {
      "name": "@xharbor/xtalk-api",
      "dependencies": {
        "@xharbor/contracts": "*",
        "@xharbor/platform-auth": "*",
        "@xharbor/platform-session": "*",
        "@xharbor/sqlite-store": "*"
      }
    },
    "apps/xtalk-web": {
      "name": "@xharbor/xtalk-web"
    },
    "node_modules/@xharbor/contracts": {
      "resolved": "packages/contracts",
      "link": true
    },
    "node_modules/@xharbor/platform-auth": {
      "resolved": "packages/platform-auth",
      "link": true
    },
    "node_modules/@xharbor/platform-session": {
      "resolved": "packages/platform-session",
      "link": true
    },
    "node_modules/@xharbor/sqlite-store": {
      "resolved": "packages/sqlite-store",
      "link": true
    },
    "node_modules/@xharbor/xbacklog-api": {
      "resolved": "apps/xbacklog-api",
      "link": true
    },
    "node_modules/@xharbor/xbacklog-web": {
      "resolved": "apps/xbacklog-web",
      "link": true
    },
    "node_modules/@xharbor/xdashboard-api": {
      "resolved": "apps/xdashboard-api",
      "link": true
    },
    "node_modules/@xharbor/xdashboard-web": {
      "resolved": "apps/xdashboard-web",
      "link": true
    },
    "node_modules/@xharbor/xgroup-api": {
      "resolved": "apps/xgroup-api",
      "link": true
    },
    "node_modules/@xharbor/xgroup-web": {
      "resolved": "apps/xgroup-web",
      "link": true
    },
    "node_modules/@xharbor/xtalk-api": {
      "resolved": "apps/xtalk-api",
      "link": true
    },
    "node_modules/@xharbor/xtalk-web": {
      "resolved": "apps/xtalk-web",
      "link": true
    },
    "packages/contracts": {
      "name": "@xharbor/contracts",
      "version": "0.1.0"
    },
    "packages/json-store": {
      "name": "@xharbor/json-store",
      "version": "0.1.0",
      "extraneous": true
    },
    "packages/platform-auth": {
      "name": "@xharbor/platform-auth",
      "version": "0.1.0",
      "dependencies": {
        "@xharbor/contracts": "0.1.0"
      }
    },
    "packages/platform-session": {
      "name": "@xharbor/platform-session",
      "version": "0.1.0",
      "dependencies": {
        "@xharbor/sqlite-store": "0.1.0"
      }
    },
    "packages/sqlite-store": {
      "name": "@xharbor/sqlite-store",
      "version": "0.1.0"
    }
  }
